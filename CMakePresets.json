{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 24,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Ninja",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "NMC_ENABLE_WARNINGS": "ON",
        "NMC_ENABLE_ASAN": "OFF",
        "NMC_ENABLE_UBSAN": "OFF",
        "NMC_ENABLE_TSAN": "OFF",
        "NMC_ENABLE_COVERAGE": "OFF",
        "NMC_ENABLE_LTO": "OFF",
        "NMC_PGO_MODE": "OFF",
        "NMC_USE_LEGACY_VENDOR_DEPS": "OFF",
        "NMC_ENABLE_MUJOCO": "OFF",
        "NMC_ENABLE_TENSORRT": "OFF",
        "NMC_BUILD_ORBITAL_CORE": "OFF",
        "NMC_BUILD_ORBITAL_BACKEND": "OFF"
      }
    },
    {
      "name": "dev",
      "displayName": "Baseline Dev (nmc)",
      "inherits": "base",
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": {
        "CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
        "VCPKG_FEATURE_FLAGS": "manifests,binarycaching",
        "VCPKG_TARGET_TRIPLET": "x64-linux",
        "VCPKG_HOST_TRIPLET": "x64-linux"
      }
    },
    {
      "name": "dev-vcpkg",
      "displayName": "Baseline Dev (vcpkg)",
      "inherits": "dev",
      "cacheVariables": {}
    },
    {
      "name": "dev-tensorrt",
      "displayName": "Baseline Dev + TensorRT (optional)",
      "inherits": "dev",
      "binaryDir": "${sourceDir}/build-tensorrt",
      "cacheVariables": {
        "NMC_ENABLE_TENSORRT": "ON"
      }
    },
    {
      "name": "debug-sanitized",
      "displayName": "Debug + ASAN/UBSAN",
      "inherits": "dev",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "NMC_ENABLE_ASAN": "ON",
        "NMC_ENABLE_UBSAN": "ON"
      }
    },
    {
      "name": "debug-tsan",
      "displayName": "Debug + TSAN",
      "inherits": "dev",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "NMC_ENABLE_TSAN": "ON"
      }
    },
    {
      "name": "debug-coverage",
      "displayName": "Debug + Coverage",
      "inherits": "dev",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "NMC_ENABLE_COVERAGE": "ON"
      }
    },
    {
      "name": "release",
      "displayName": "Release + LTO + PGO(auto)",
      "inherits": "dev",
      "binaryDir": "${sourceDir}/build-release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "NMC_ENABLE_LTO": "ON",
        "NMC_PGO_MODE": "AUTO",
        "NMC_USE_LEGACY_VENDOR_DEPS": "OFF"
      }
    },
    {
      "name": "release-pgo-generate",
      "displayName": "Release + LTO + PGO(generate)",
      "inherits": "release",
      "binaryDir": "${sourceDir}/build-release-pgo-gen",
      "cacheVariables": {
        "NMC_PGO_MODE": "GENERATE"
      }
    },
    {
      "name": "release-pgo-use",
      "displayName": "Release + LTO + PGO(use)",
      "inherits": "release",
      "binaryDir": "${sourceDir}/build-release-pgo-use",
      "cacheVariables": {
        "NMC_PGO_MODE": "USE"
      }
    },
    {
      "name": "orbital-core-only",
      "displayName": "Orbital Core Optional Targets",
      "inherits": "dev",
      "binaryDir": "${sourceDir}/build-orbital-core",
      "cacheVariables": {
        "NMC_BUILD_ORBITAL_CORE": "ON",
        "NMC_BUILD_ORBITAL_BACKEND": "OFF"
      }
    },
    {
      "name": "orbital-stack",
      "displayName": "Orbital Optional Stack (Core + Backend)",
      "inherits": "orbital-core-only",
      "binaryDir": "${sourceDir}/build-orbital",
      "cacheVariables": {
        "NMC_BUILD_ORBITAL_BACKEND": "ON"
      }
    },
    {
      "name": "ci",
      "displayName": "CI Baseline (nmc)",
      "inherits": "base",
      "binaryDir": "${sourceDir}/build-ci",
      "cacheVariables": {
        "CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
        "VCPKG_FEATURE_FLAGS": "manifests,binarycaching",
        "VCPKG_TARGET_TRIPLET": "x64-linux",
        "VCPKG_HOST_TRIPLET": "x64-linux",
        "NMC_USE_LEGACY_VENDOR_DEPS": "OFF"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "build",
      "configurePreset": "dev",
      "targets": [
        "nmc",
        "nmc_inference_parity_test"
      ]
    },
    {
      "name": "build-vcpkg",
      "configurePreset": "dev-vcpkg",
      "targets": [
        "nmc",
        "nmc_inference_parity_test"
      ]
    },
    {
      "name": "build-tensorrt",
      "configurePreset": "dev-tensorrt",
      "targets": [
        "nmc",
        "nmc_inference_parity_test"
      ]
    },
    {
      "name": "build-debug",
      "configurePreset": "debug-sanitized",
      "targets": [
        "nmc",
        "nmc_inference_parity_test"
      ]
    },
    {
      "name": "build-debug-tsan",
      "configurePreset": "debug-tsan",
      "targets": [
        "nmc"
      ]
    },
    {
      "name": "build-debug-coverage",
      "configurePreset": "debug-coverage",
      "targets": [
        "nmc"
      ]
    },
    {
      "name": "build-release",
      "configurePreset": "release",
      "targets": [
        "nmc"
      ]
    },
    {
      "name": "build-release-pgo-generate",
      "configurePreset": "release-pgo-generate",
      "targets": [
        "nmc"
      ]
    },
    {
      "name": "build-release-pgo-use",
      "configurePreset": "release-pgo-use",
      "targets": [
        "nmc"
      ]
    },
    {
      "name": "build-orbital",
      "configurePreset": "orbital-core-only",
      "targets": [
        "nmc",
        "orbital_core",
        "orbital_core_tests",
        "orbital_baseline_tests",
        "orbital_control_benchmark"
      ]
    },
    {
      "name": "build-orbital-backend",
      "configurePreset": "orbital-stack",
      "targets": [
        "orbital_backend"
      ]
    },
    {
      "name": "build-ci",
      "configurePreset": "ci",
      "targets": [
        "nmc",
        "nmc_inference_parity_test"
      ]
    }
  ],
  "testPresets": [
    {
      "name": "test",
      "configurePreset": "dev",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "test-ci",
      "configurePreset": "ci",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
