{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 24,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "dev",
      "displayName": "Dev RelWithDebInfo",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "NMC_ENABLE_WARNINGS": "ON",
        "NMC_ENABLE_ASAN": "OFF",
        "NMC_ENABLE_UBSAN": "OFF",
        "NMC_ENABLE_LTO": "OFF",
        "NMC_ENABLE_MUJOCO": "OFF"
      }
    },
    {
      "name": "debug-sanitized",
      "displayName": "Debug with Sanitizers",
      "inherits": "dev",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "NMC_ENABLE_ASAN": "ON",
        "NMC_ENABLE_UBSAN": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "build",
      "configurePreset": "dev",
      "targets": [
        "nmc"
      ]
    },
    {
      "name": "build-debug",
      "configurePreset": "debug-sanitized",
      "targets": [
        "nmc"
      ]
    }
  ],
  "testPresets": [
    {
      "name": "test",
      "configurePreset": "dev",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
