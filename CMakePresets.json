{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 24,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "dev",
      "displayName": "Baseline Dev (nmc)",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "NMC_EIGEN_ROOT": "${sourceDir}/lib/eigen-source",
        "NMC_TORCH_ROOT": "${sourceDir}/lib/libtorch",
        "NMC_ENABLE_WARNINGS": "ON",
        "NMC_ENABLE_ASAN": "OFF",
        "NMC_ENABLE_UBSAN": "OFF",
        "NMC_ENABLE_LTO": "OFF",
        "NMC_ENABLE_MUJOCO": "OFF"
      }
    },
    {
      "name": "debug-sanitized",
      "displayName": "Baseline Debug + Sanitizers",
      "inherits": "dev",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "NMC_ENABLE_ASAN": "ON",
        "NMC_ENABLE_UBSAN": "ON"
      }
    },
    {
      "name": "orbital-stack",
      "displayName": "Orbital Optional Stack (Core + Backend)",
      "inherits": "dev",
      "binaryDir": "${sourceDir}/build-orbital",
      "cacheVariables": {
        "NMC_BUILD_ORBITAL_CORE": "ON",
        "NMC_BUILD_ORBITAL_BACKEND": "ON"
      }
    },
    {
      "name": "orbital-core-only",
      "displayName": "Orbital Core Optional Targets",
      "inherits": "dev",
      "binaryDir": "${sourceDir}/build-orbital-core",
      "cacheVariables": {
        "NMC_BUILD_ORBITAL_CORE": "ON",
        "NMC_BUILD_ORBITAL_BACKEND": "OFF"
      }
    },
    {
      "name": "ci",
      "displayName": "CI Baseline (nmc)",
      "inherits": "dev",
      "binaryDir": "${sourceDir}/build-ci",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "NMC_ENABLE_WARNINGS": "ON",
        "NMC_ENABLE_ASAN": "OFF",
        "NMC_ENABLE_UBSAN": "OFF",
        "NMC_ENABLE_LTO": "OFF",
        "NMC_ENABLE_MUJOCO": "OFF",
        "NMC_BUILD_ORBITAL_CORE": "ON",
        "NMC_BUILD_ORBITAL_BACKEND": "OFF"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "build",
      "configurePreset": "dev",
      "targets": [
        "nmc"
      ]
    },
    {
      "name": "build-debug",
      "configurePreset": "debug-sanitized",
      "targets": [
        "nmc"
      ]
    },
    {
      "name": "build-orbital",
      "configurePreset": "orbital-core-only",
      "targets": [
        "nmc",
        "orbital_core",
        "orbital_core_tests",
        "orbital_baseline_tests",
        "orbital_control_benchmark"
      ]
    },
    {
      "name": "build-orbital-backend",
      "configurePreset": "orbital-stack",
      "targets": [
        "orbital_backend"
      ]
    },
    {
      "name": "build-ci",
      "configurePreset": "ci",
      "targets": [
        "nmc"
      ]
    }
  ],
  "testPresets": [
    {
      "name": "test",
      "configurePreset": "dev",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "test-ci",
      "configurePreset": "ci",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
